---
import { render } from 'astro:content'

import { getProjects } from '../../utils/projects'

import Layout from '../../layouts/AppLayout.astro'
import TableOfContents from '../../components/TableOfContents.astro'

import '../../styles/post.css'

export async function getStaticPaths() {
  const projects = await getProjects()
  return projects.map(project => ({
    params: { id: project.id },
    props: { project },
  }))
}

const { project } = Astro.props
const { Content, headings } = await render(project)
---

<Layout withExternalLinks={false}>
  <div class="mt-8 flex flex-col gap-10 md:mt-12 md:flex-row">
    <!-- Desktop Table of Contents -->
    <TableOfContents
      headings={headings}
      class="sticky top-24 hidden max-h-[calc(100vh-8rem)] w-48 shrink-0 self-start overflow-y-auto md:block"
    />

    <main class="max-w-2xl">
      <!-- Project Header -->
      <header class="mb-8 md:mb-10">
        <h1 class="text-text text-2xl font-medium">
          {project.data.title}
        </h1>
        <p class="text-muted mt-2 text-sm leading-relaxed">
          {project.data.description}
        </p>
        <div class="mt-3 flex flex-wrap items-center gap-2">
          {
            project.data.tags.map((tag: string) => (
              <span class="text-muted bg-surface-2 rounded-sm px-2 py-0.5 font-mono text-xs">
                {tag}
              </span>
            ))
          }
          <a
            href={project.data.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent hover:text-text ml-1 inline-flex items-center gap-1 font-mono text-sm transition-colors duration-150"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="currentColor"
              viewBox="0 0 24 24"
              class="size-3.5"
            >
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z"
              ></path>
            </svg>
            source
          </a>
        </div>
      </header>

      <!-- Mobile Table of Contents -->
      <TableOfContents headings={headings} class="mb-10 block md:hidden" />

      <!-- Project Content -->
      <article class="prose">
        <Content />
      </article>
    </main>
  </div>
</Layout>
