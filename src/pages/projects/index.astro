---
import { getProjects } from '../../utils/projects'
import Layout from '../../layouts/AppLayout.astro'
import Link from '../../components/Link.astro'

const projects = await getProjects()
---

<Layout withExternalLinks={false}>
  <main class="mt-8 max-w-2xl md:mt-12">
    {
      projects.length === 0 ? (
        <p class="text-muted">No projects yet.</p>
      ) : (
        <div class="group/list flex flex-col gap-1">
          {projects.map(project => (
            <article class="group w-full transition-opacity duration-200 group-hover/list:opacity-40 hover:opacity-100!">
              <Link
                href={`/projects/${project.id}`}
                class="flex w-full items-center gap-4"
              >
                <span class="text-text shrink-0">{project.data.title}</span>
                <span class="bg-muted h-px flex-1 opacity-30 group-hover:opacity-50" />
                <span class="text-muted hidden shrink-0 font-mono text-sm tracking-tight opacity-80 group-hover:opacity-100 sm:inline">
                  {project.data.tags.join(', ')}
                </span>
              </Link>
            </article>
          ))}
        </div>
      )
    }
  </main>
</Layout>
